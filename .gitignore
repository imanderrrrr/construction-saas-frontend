# Dependencies
# no trailing slash: also ignore a symlink named node_modules, not only a directory
node_modules
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
build/
.next/

# Environment variables — never commit real secrets
.env
.env.*
!.env.example
!.env.test

# Editor / OS
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Type checking cache
*.tsbuildinfo

# Coverage
coverage/

# Vite cache
.vite/

# Playwright E2E artifacts
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
