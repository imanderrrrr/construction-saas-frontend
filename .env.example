# Environment variables for the SPA build.
# Copy this file to .env for local development.
# NEVER commit the real .env (the .gitignore already enforces it).
#
# IMPORTANT: VITE_* variables are PUBLIC. Anything you put here ends up
# in the production JS bundle and is readable by every visitor. Do not
# put secrets here — the only thing that belongs is the public API URL.

# ── API base URL ─────────────────────────────────────────────────────
# Local dev points at the Spring Boot port exposed by the backend
# repo's docker-compose / `./gradlew bootRun`.
#
# In Vercel, leave this UNSET (or matching the prod backend) and let
# vercel.json `rewrites` proxy `/api/*` to the production backend so
# the SPA never embeds a cross-origin URL in its bundle.
VITE_API_URL=http://localhost:58080

# ── Sentry (optional, error tracking) ────────────────────────────────
# Leave VITE_SENTRY_DSN empty (or unset) to disable Sentry. When unset,
# initSentry() is a no-op and the SPA behaves identically — no network
# calls, no breadcrumbs, no init.
#
# To enable in staging/preview/prod, set the project DSN below. Use
# distinct VITE_SENTRY_ENVIRONMENT values per deploy so dashboards and
# alert rules don't mix populations.
#
# PII handling: send-default-pii is hard-coded false. The custom
# beforeSend in src/app/lib/sentry.ts strips Authorization / Cookie /
# X-XSRF-TOKEN headers, request body, query string, and any payload
# field whose key matches password / token / secret / mfa / etc. It
# also drops fetch breadcrumbs hitting auth endpoints (their URLs may
# carry reset / invitation tokens).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=dev
# Typically the git SHA or a CI-injected version string. Empty = unknown.
VITE_SENTRY_RELEASE=

# ── Paddle Billing (admin-only checkout) ─────────────────────────────
# Public client-side token for Paddle.js. Despite the "token" name, it
# is designed to live in the browser bundle — it is NOT a secret. The
# real Paddle API key stays on the backend. This token is only used to
# render Paddle Checkout overlays for transactions ALREADY minted by
# the backend's POST /api/v1/billing/checkout endpoint; the frontend
# never decides prices, currencies, or trials.
#
# DO NOT put a live (production) token here. Keep this file pinned to
# a sandbox client token for development and previews. Production
# deploys must inject the prod token at build time via the hosting
# provider's environment, not via this committed file.
VITE_PADDLE_CLIENT_TOKEN=

# Defaults to "sandbox" in src/app/lib/paddle.ts. Set to "production"
# ONLY in real production builds; any other value (or empty) is treated
# as "sandbox" by the loader so we can never accidentally hit live by
# omission or typo.
VITE_PADDLE_ENVIRONMENT=sandbox
